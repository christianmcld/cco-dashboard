---
import Layout from '../layouts/Layout.astro';
import data from '../data/belief-score.json';

const d = data as any;
const generated = d.generated_at ? new Date(d.generated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : null;
function tier(s) { return s >= 75 ? 'Strong' : s >= 50 ? 'Building' : s >= 25 ? 'Thin' : 'Missing'; }
---

<Layout title="Belief Score · FieldWork">
  <div class="max-w-[1000px] mx-auto px-5 lg:px-10 py-8">

    <header class="mb-8">
      <p class="section-label mb-2">Content Trust</p>
      <h1 class="text-4xl font-display font-semibold tracking-tight mb-2">Belief Score</h1>
      <p class="text-text-secondary max-w-2xl">
        How your own posts on @{d.handle} are building the six FieldWork BELIEF trust pillars.
        Scored from your recent content, so you can see which pillars you are reinforcing and which you are neglecting.
      </p>
    </header>

    {d.total_pieces === 0 ? (
      <div class="card p-10 text-center text-text-secondary">
        No score yet. The engine scores your posted content on the next refresh.
      </div>
    ) : (
      <>
        <!-- OVERALL -->
        <div class="flex flex-col md:flex-row items-center gap-6 mb-10">
          <div class="card p-8 text-center" style="min-width:220px;">
            <div class="stat-value" style="font-size:3.4rem;line-height:1;">{d.overall_score}</div>
            <div class="section-label mt-2">Overall belief score</div>
            <div class="text-xs text-text-secondary mt-1 font-label">{d.total_pieces} posts analyzed{generated ? ' · ' + generated : ''}</div>
          </div>
          <div class="flex-1">
            <p class="text-sm text-text-secondary mb-2">
              Each pillar is scored by how much of your content actively builds it. Spread your posts across all six to be maximally believable.
            </p>
            {d.weakest && d.weakest.length > 0 && (
              <p class="text-sm">
                <span class="font-semibold">Neglected right now:</span>
                {d.weakest.map((w, i) => (<span> {i > 0 ? '·' : ''} <span class="text-accent font-semibold">{w.name}</span> ({w.score})</span>))}
                <span class="text-text-secondary"> — make your next posts lean here.</span>
              </p>
            )}
          </div>
        </div>

        <!-- PILLARS -->
        <div class="space-y-3">
          {d.pillars.map((p) => (
            <div class="card p-5">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-11 h-11 rounded-full flex items-center justify-center font-display font-bold text-lg" style="background:var(--color-accent);color:var(--color-on-accent);">{p.letter}</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-baseline justify-between gap-3">
                    <h3 class="font-display font-semibold">{p.name}</h3>
                    <span class="font-label text-sm"><span class="font-bold" style={`color:${p.score >= 50 ? 'var(--color-ink)' : 'var(--color-error)'}`}>{p.score}</span><span class="text-text-secondary">/100 · {tier(p.score)}</span></span>
                  </div>
                  <div class="h-2 w-full bg-surface-bright rounded-full overflow-hidden mt-2">
                    <div class="h-full rounded-full" style={`width:${p.score}%;background:var(--color-accent);`}></div>
                  </div>
                  <p class="text-xs text-text-secondary mt-2 font-label">{p.count} of {d.total_pieces} posts build this pillar</p>
                  {p.sample && <p class="text-xs text-text-secondary mt-1 italic line-clamp-1">e.g. "{p.sample}"</p>}
                </div>
              </div>
            </div>
          ))}
        </div>

        <p class="text-center text-text-secondary text-xs mt-10 font-label">
          BELIEF = Bold Authority · Earned Proof · Lived Story · Intimate Humanity · Esteemed Admiration · Faithful Service
        </p>
      </>
    )}
  </div>
</Layout>
