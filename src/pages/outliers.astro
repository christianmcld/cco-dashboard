---
import Layout from '../layouts/Layout.astro';
import data from '../data/outliers.json';

const items = (data.outliers || []).slice();
const accounts = data.accounts || [];
const creatorList = [...new Set(items.map((o) => o.source_account))].sort();
const totalDetected = data.outlier_total_detected || 0;
const totalMatches = data.message_match_total || 0;
const generatedAt = data.generated_at ? new Date(data.generated_at) : null;
const nOutliers = items.filter((o) => o.is_outlier).length;
const nMatches = items.filter((o) => o.is_message_match).length;

function fmt(n) {
  if (n == null) return '0';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
  return String(n);
}
function scriptBeats(s) {
  if (Array.isArray(s)) return s;
  if (typeof s === 'string') return s.split(/\n+/).filter(Boolean);
  return [];
}
const lastUpdated = generatedAt
  ? generatedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
  : '—';
---

<Layout title="Content Outliers · FieldWork">
  <script is:inline>
    document.addEventListener('alpine:init', () => {
      window.Alpine.store('ui', { board: 'all', creator: 'all' });
    });
  </script>
  <div class="max-w-[1100px] mx-auto px-5 lg:px-10 py-8">

    <!-- HEADER -->
    <header class="mb-8">
      <p class="section-label mb-2">Content Engine</p>
      <h1 class="text-4xl font-display font-semibold tracking-tight mb-2">Content Outliers</h1>
      <p class="text-text-secondary max-w-2xl">
        Two signals: competitor reels that beat their own baseline (<span class="text-accent font-semibold">outliers</span>),
        and reels whose copy fits the FieldWork message (<span class="font-semibold">FieldWork matches</span>) even when they
        are not outliers. Each is a proven template. Approve one to get your hooks and a script in your voice.
      </p>
    </header>

    <!-- STATS -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
      <div class="card p-4">
        <div class="stat-value">{items.length}</div>
        <div class="section-label mt-1">Ready to record</div>
      </div>
      <div class="card p-4">
        <div class="stat-value">{totalDetected}</div>
        <div class="section-label mt-1">Outliers detected</div>
      </div>
      <div class="card p-4">
        <div class="stat-value">{totalMatches}</div>
        <div class="section-label mt-1">FieldWork matches</div>
      </div>
      <div class="card p-4">
        <div class="stat-value" style="font-size:1.4rem;">{lastUpdated}</div>
        <div class="section-label mt-1">Last refresh</div>
      </div>
    </div>

    <!-- FILTER -->
    <div class="flex items-center gap-2 mb-6 flex-wrap">
      <button class="tab-button" :class="$store.ui.board === 'all' ? 'active' : ''" @click="$store.ui.board = 'all'">All ({items.length})</button>
      <button class="tab-button" :class="$store.ui.board === 'outliers' ? 'active' : ''" @click="$store.ui.board = 'outliers'">Outliers ({nOutliers})</button>
      <button class="tab-button" :class="$store.ui.board === 'match' ? 'active' : ''" @click="$store.ui.board = 'match'">FieldWork matches ({nMatches})</button>
    </div>

    <!-- CREATOR FILTER -->
    <div class="flex items-center gap-2 mb-6 flex-wrap">
      <span class="section-label mr-1">Creator</span>
      <button class="tab-button" :class="$store.ui.creator === 'all' ? 'active' : ''" @click="$store.ui.creator = 'all'">All creators</button>
      {creatorList.map((c) => (
        <button class="tab-button" :class={`$store.ui.creator === '${c}' ? 'active' : ''`} @click={`$store.ui.creator = '${c}'`}>@{c}</button>
      ))}
    </div>

    <!-- CARDS -->
    <div class="space-y-4">
      {items.map((o, i) => (
        <article
          class="card p-5"
          x-show={`($store.ui.creator === 'all' || $store.ui.creator === '${o.source_account}') && ($store.ui.board === 'all' || ($store.ui.board === 'outliers' && ${o.is_outlier}) || ($store.ui.board === 'match' && ${o.is_message_match}))`}
          x-transition
          x-data={`{
            open: false,
            done: false,
            init() { try { this.done = localStorage.getItem('cco-done-${o.source_url}') === '1'; } catch(e){} },
            markDone() { this.done = !this.done; try { localStorage.setItem('cco-done-${o.source_url}', this.done ? '1' : '0'); } catch(e){} },
            addToLib() {
              var item = ${JSON.stringify({
                id: o.source_url,
                headline: o.headline || (o.my_hooks && o.my_hooks[0]) || o.recommended_angle || 'Idea',
                angle: o.recommended_angle || '',
                hooks: o.my_hooks || [],
                talking_points: o.my_talking_points || [],
                body_copy: o.my_body_copy || '',
                script: scriptBeats(o.my_script_summary),
                guidance: o.production_guidance || [],
                source: '@' + o.source_account,
                framework: o.hook_framework || '',
              })};
              var lib = []; try { lib = JSON.parse(localStorage.getItem('cco-library')||'[]'); } catch(e){}
              if(!lib.some(function(x){ return (x.headline||x.title) === item.headline; })){
                item.added = Date.now(); lib.unshift(item);
                try { localStorage.setItem('cco-library', JSON.stringify(lib)); } catch(e){}
              }
            }
          }`}
          x-bind:class="done ? 'opacity-55' : ''"
        >
          <!-- top row -->
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <div class="flex items-start gap-3 min-w-0">
              {o.thumbnail && (
                <a href={o.source_url} target="_blank" rel="noopener" class="block flex-shrink-0 relative group">
                  <img src={o.thumbnail} alt={`Reel by @${o.source_account}`} loading="lazy" class="w-16 h-24 object-cover rounded-md border border-border" />
                  <span class="absolute inset-0 flex items-center justify-center opacity-80 group-hover:opacity-100 transition-opacity">
                    <span class="w-6 h-6 rounded-full bg-black/45 flex items-center justify-center">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><polygon points="6 4 20 12 6 20 6 4"></polygon></svg>
                    </span>
                  </span>
                </a>
              )}
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="source-icon source-ig">IG</span>
                  <a href={o.source_url} target="_blank" rel="noopener" class="font-display font-semibold hover:text-accent transition-colors truncate">@{o.source_account}</a>
                  {o.hook_framework && <span class="badge badge-grey">{o.hook_framework}</span>}
                </div>
                <p class="text-text-secondary text-sm mt-2 line-clamp-3">{o.source_caption || '(no caption)'}</p>
              </div>
            </div>
            <div class="text-right flex-shrink-0 space-y-1">
              {o.is_outlier && <div class="badge badge-lime" style="font-size:0.8rem;">{o.outlier_score}x avg</div>}
              {o.is_message_match && <div class="badge badge-match" style="font-size:0.8rem;">FieldWork {o.relevance_score}</div>}
              <div class="text-text-secondary text-xs font-label">{fmt(o.source_plays)} plays · base {fmt(o.account_baseline)}</div>
            </div>
          </div>

          <!-- fieldwork fit reason (message matches) -->
          {o.is_message_match && o.relevance_reason && (
            <div class="mt-3 px-3 py-2 rounded-md text-sm" style="background: color-mix(in srgb, var(--color-accent) 9%, transparent); border:1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);">
              <span class="font-label font-bold text-xs uppercase tracking-wider">Fits FieldWork · </span>{o.relevance_reason}
            </div>
          )}

          <!-- why + angle -->
          <div class="mt-4 grid md:grid-cols-2 gap-4">
            <div>
              <p class="section-label mb-1">Why it worked</p>
              <p class="text-sm leading-relaxed">{o.why_it_worked}</p>
            </div>
            <div>
              <p class="section-label mb-1">Your angle</p>
              <p class="text-sm leading-relaxed">{o.recommended_angle}</p>
            </div>
          </div>

          <!-- actions -->
          <div class="mt-4 flex items-center gap-2 flex-wrap">
            <button class="lets-go-btn px-4 py-2 text-sm" @click="open = !open" x-text="open ? 'Hide hooks & script' : 'Get hooks & script'"></button>
            <button class="tab-button" @click="addToLib(); $el.textContent='✓ Added'; setTimeout(()=>$el.textContent='Add to Library',2000)">Add to Library</button>
            <a href={o.source_url} target="_blank" rel="noopener" class="emulate-btn px-4 py-2 text-sm border rounded-full">Watch original</a>
            <button class="tab-button" @click="markDone()" x-text="done ? '✓ Recorded' : 'Mark recorded'"></button>
          </div>

          <!-- expandable -->
          <div x-show="open" x-transition class="mt-5 pt-5 border-t border-border grid md:grid-cols-2 gap-6">
            <div>
              <p class="section-label mb-2">5 hooks (in your voice)</p>
              <ul class="space-y-2">
                {(o.my_hooks || []).map((h) => (
                  <li class="text-sm flex gap-2"><span class="text-accent font-bold flex-shrink-0">→</span><span>{h}</span></li>
                ))}
              </ul>
            </div>
            <div>
              <p class="section-label mb-2">Script outline</p>
              <ol class="space-y-2">
                {scriptBeats(o.my_script_summary).map((beat) => (
                  <li class="text-sm flex gap-2"><span class="text-text-secondary flex-shrink-0 font-label text-xs mt-0.5">●</span><span>{beat}</span></li>
                ))}
              </ol>
            </div>
          </div>
        </article>
      ))}
    </div>

    {items.length === 0 && (
      <div class="card p-10 text-center text-text-secondary">No outliers yet. Run the scraper to populate this page.</div>
    )}

    <p class="text-center text-text-secondary text-xs mt-10 font-label">
      Refreshed every 3 days · tracking {accounts.map(a => '@' + a.handle).join('  ·  ')}
    </p>
  </div>
</Layout>
