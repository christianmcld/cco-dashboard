---
import Layout from '../layouts/Layout.astro';
import seedData from '../data/library.json';
const seed = (seedData as any).items || [];
---

<Layout title="Library · FieldWork">
  <script id="library-seed" type="application/json" is:inline set:html={JSON.stringify(seed).replace(/</g, '\\u003c')}></script>
  <div class="max-w-[1100px] mx-auto px-5 lg:px-10 py-8"
    x-data={`{
      seed: [],
      extras: [],
      doneMap: {},
      openMap: {},
      filter: 'todo',
      toggleOpen(k){ this.openMap[k] = !this.openMap[k]; },
      load(){
        try { this.seed = JSON.parse(document.getElementById('library-seed').textContent); } catch(e){ this.seed = []; }
        try { this.extras = JSON.parse(localStorage.getItem('cco-library')||'[]'); } catch(e){ this.extras = []; }
        try { this.doneMap = JSON.parse(localStorage.getItem('cco-lib-done')||'{}'); } catch(e){ this.doneMap = {}; }
      },
      key(it){ return it.id || it.source_url || it.title || it.headline; },
      beliefLabel(code){ return ({B:'Bold Authority',E:'Earned Proof',L:'Lived Story',I:'Intimate Humanity',E2:'Esteemed Admiration',F:'Faithful Service'})[code] || code; },
      get items(){
        var self=this;
        var all = this.seed.concat(this.extras);
        var seen = {}; var out = [];
        all.forEach(function(it, idx){
          var k = self.key(it) || ('item-' + idx);
          if(seen[k]) return;            // drop duplicate keys (added item == a seed)
          seen[k] = true;
          out.push(Object.assign({}, it, { _key: k, done: !!self.doneMap[k] }));
        });
        return out;
      },
      get shown(){
        if(this.filter==='todo') return this.items.filter(function(x){return !x.done;});
        if(this.filter==='done') return this.items.filter(function(x){return x.done;});
        return this.items;
      },
      get todoCount(){ return this.items.filter(function(x){return !x.done;}).length; },
      toggle(k){ this.doneMap[k] = !this.doneMap[k]; try{localStorage.setItem('cco-lib-done', JSON.stringify(this.doneMap));}catch(e){} },
      removeExtra(it){ var k=this.key(it); this.extras = this.extras.filter(function(x){ return (x.id||x.source_url||x.title||x.headline) !== k; }); try{localStorage.setItem('cco-library', JSON.stringify(this.extras));}catch(e){} },
      asText(it){
        var l=[it.headline||it.title||'']; if(it.angle) l.push('', it.angle);
        if(it.hooks&&it.hooks.length){ l.push('','HOOKS:'); it.hooks.forEach(function(h){l.push('- '+h);}); }
        if(it.talking_points&&it.talking_points.length){ l.push('','WHAT TO SAY:'); it.talking_points.forEach(function(t){l.push('- '+t);}); }
        if(it.body_copy){ l.push('','WORD-FOR-WORD:', it.body_copy); }
        else if(it.script&&it.script.length){ l.push('','SCRIPT:'); it.script.forEach(function(b){l.push('- '+b);}); }
        if(it.guidance&&it.guidance.length){ l.push('','HOW TO SHOOT:'); it.guidance.forEach(function(g){l.push('- '+g);}); }
        return l.join('\\n');
      }
    }`} x-init="load()">

    <header class="mb-6">
      <p class="section-label mb-2">Content Engine</p>
      <h1 class="text-4xl font-display font-semibold tracking-tight mb-2">Library</h1>
      <p class="text-text-secondary max-w-2xl">
        Your content to-do list. Ready-to-shoot packs modeled on what is working in your niche, each with
        a headline, hooks, a word-for-word script, and how to shoot it. Check them off as you record.
      </p>
    </header>

    <div class="flex items-center gap-2 mb-6 flex-wrap">
      <button class="tab-button" :class="filter==='todo'?'active':''" @click="filter='todo'">To record (<span x-text="todoCount"></span>)</button>
      <button class="tab-button" :class="filter==='done'?'active':''" @click="filter='done'">Recorded</button>
      <button class="tab-button" :class="filter==='all'?'active':''" @click="filter='all'">All (<span x-text="items.length"></span>)</button>
    </div>

    <div class="card p-10 text-center text-text-secondary" x-show="items.length === 0">
      Nothing here yet. The engine fills this every 3 days, or hit <span class="font-semibold">Add to Library</span> on the dashboard or Content Outliers.
    </div>

    <div class="space-y-4">
      <template x-for="it in shown" :key="it._key">
        <article class="card p-5" :class="it.done ? 'opacity-55' : ''">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <h3 class="font-display font-semibold text-base" :class="it.done ? 'line-through' : ''" x-text="it.headline || it.title"></h3>
              <p class="text-text-secondary text-xs mt-1 font-label">
                <span x-text="it.source || ''"></span>
                <template x-if="it.outlier_score"><span> &middot; <span x-text="it.outlier_score + 'x'"></span></span></template>
                <template x-if="it.framework"><span> &middot; <span x-text="it.framework"></span></span></template>
              </p>
              <div class="flex gap-1.5 flex-wrap mt-2" x-show="it.belief_tags && it.belief_tags.length">
                <template x-for="(bt, bi) in (it.belief_tags||[])" :key="bi">
                  <span class="badge badge-match" :title="beliefLabel(bt)" x-text="(bt==='E2'?'E':bt) + ' · ' + beliefLabel(bt)"></span>
                </template>
              </div>
            </div>
            <div class="flex gap-2 flex-shrink-0">
              <button class="lets-go-btn px-4 py-1.5 text-sm rounded-full" @click="toggleOpen(it._key)" x-text="openMap[it._key] ? 'Collapse' : 'Expand'"></button>
              <button class="tab-button" @click="toggle(it._key)" x-text="it.done ? '✓ Recorded' : 'Mark recorded'"></button>
              <button class="tab-button" @click="navigator.clipboard.writeText(asText(it)); $el.textContent='Copied!'; setTimeout(()=>$el.textContent='Copy all',1500)">Copy all</button>
            </div>
          </div>

          <!-- collapsed teaser -->
          <p class="text-sm text-text-secondary mt-3 line-clamp-1" x-show="!openMap[it._key]" x-text="(it.hooks && it.hooks[0]) || it.angle || ''"></p>

          <!-- expanded detail (accordion) -->
          <div x-show="openMap[it._key]" x-transition.opacity>
          <p class="text-sm text-text-secondary mt-3" x-show="it.angle" x-text="it.angle"></p>

          <div class="mt-4 grid md:grid-cols-2 gap-6">
            <div x-show="it.hooks && it.hooks.length">
              <p class="section-label mb-2">Hooks</p>
              <ul class="space-y-1.5">
                <template x-for="(h, hi) in (it.hooks||[])" :key="hi">
                  <li class="text-sm flex gap-2"><span class="text-accent font-bold flex-shrink-0">&rarr;</span><span x-text="h"></span></li>
                </template>
              </ul>
            </div>
            <div x-show="it.guidance && it.guidance.length">
              <p class="section-label mb-2">How to shoot it</p>
              <ul class="space-y-1.5">
                <template x-for="(g, gi) in (it.guidance||[])" :key="gi">
                  <li class="text-sm flex gap-2"><span class="text-text-secondary flex-shrink-0 text-xs mt-0.5">&bull;</span><span x-text="g"></span></li>
                </template>
              </ul>
            </div>
          </div>

          <div class="mt-4" x-show="it.talking_points && it.talking_points.length">
            <p class="section-label mb-2">What to say (record this)</p>
            <ul class="space-y-1.5">
              <template x-for="(tp, ti) in (it.talking_points||[])" :key="ti">
                <li class="text-sm flex gap-2"><span class="text-accent flex-shrink-0">•</span><span x-text="tp"></span></li>
              </template>
            </ul>
          </div>
          <div class="mt-4" x-show="it.body_copy">
            <p class="section-label mb-2">Or read word-for-word</p>
            <p class="text-sm leading-relaxed bg-surface-bright/40 rounded-lg p-3 border border-border" x-text="it.body_copy"></p>
          </div>
          <div class="mt-4" x-show="!it.body_copy && it.script && it.script.length">
            <p class="section-label mb-2">Script outline</p>
            <ol class="space-y-1.5">
              <template x-for="(b, bi) in (it.script||[])" :key="bi">
                <li class="text-sm flex gap-2"><span class="text-text-secondary flex-shrink-0 text-xs mt-0.5">&bull;</span><span x-text="b"></span></li>
              </template>
            </ol>
          </div>
          </div>
        </article>
      </template>
    </div>
  </div>
</Layout>
