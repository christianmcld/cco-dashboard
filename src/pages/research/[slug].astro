---
import Layout from '../../layouts/Layout.astro';

// Load all research JSON files
const researchFiles = import.meta.glob('../../data/research/*.json', { eager: true });

export function getStaticPaths() {
  const files = import.meta.glob('../../data/research/*.json', { eager: true });
  return Object.entries(files).map(([path, mod]: [string, any]) => {
    const data = mod.default || mod;
    const filename = path.split('/').pop()?.replace('.json', '') || '';
    const slug = filename.replace(/^_sample-/, '');
    return {
      params: { slug },
      props: { data },
    };
  });
}

const { data } = Astro.props;
const { slug } = Astro.params;

// Profile info
const ig = data.social_profiles?.instagram || {};
const displayName = ig.full_name || ig.handle || data.query;
const handle = ig.handle || slug;

// Helpers
function formatNumber(n: number): string {
  if (!n) return '0';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
  return n.toLocaleString();
}

function formatDate(ts: string): string {
  if (!ts) return '';
  return new Date(ts).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function getFrameworkColor(framework: string): { badge: string; bg: string; text: string } {
  const map: Record<string, { badge: string; bg: string; text: string }> = {
    'Cost Replacement': { badge: 'badge-lime', bg: 'bg-accent/10', text: 'text-accent' },
    'Capability Reveal': { badge: 'badge-lime', bg: 'bg-accent/10', text: 'text-accent' },
    'Pattern Interrupt': { badge: 'badge-error', bg: 'bg-error/10', text: 'text-error' },
    'Curiosity Gap': { badge: 'badge-warm', bg: 'bg-warm/10', text: 'text-warm' },
    'Pain Point': { badge: 'badge-error', bg: 'bg-error/10', text: 'text-error' },
    'Before/After': { badge: 'badge-lime', bg: 'bg-accent/10', text: 'text-accent' },
    'Proof First': { badge: 'badge-lime', bg: 'bg-accent/10', text: 'text-accent' },
    'Contrarian': { badge: 'badge-warm', bg: 'bg-warm/10', text: 'text-warm' },
    'Question': { badge: 'badge-grey', bg: 'bg-emerging/10', text: 'text-emerging' },
    'Test/Experiment': { badge: 'badge-grey', bg: 'bg-emerging/10', text: 'text-emerging' },
  };
  return map[framework] || { badge: 'badge-grey', bg: 'bg-emerging/10', text: 'text-emerging' };
}

const posts = data.viral_posts || [];
const ads = data.ads || [];
const competitors = data.competitors || [];
const analysis = data.analysis || {};

// Count active/inactive ads
const activeAds = ads.filter((a: any) => a.is_active);
const inactiveAds = ads.filter((a: any) => !a.is_active);
const maxDaysLive = ads.length > 0 ? Math.max(...ads.map((a: any) => a.days_live || 0), 90) : 90;

// Re-research CLI command
const reResearchCmd = `cd ~/content-engine && uv run python3 scripts/competitor-research.py '${data.query?.replace(/'/g, "\\'") || '@' + handle}'`;

// Social profiles for the card row
const socialPlatforms: { platform: string; icon: string; color: string; handle: string; followers?: number; link: string }[] = [];

if (ig.handle) {
  socialPlatforms.push({
    platform: 'Instagram',
    icon: 'ig',
    color: 'linear-gradient(45deg, #405de6, #c13584, #fd1d1d, #f56040)',
    handle: `@${ig.handle}`,
    followers: ig.followers,
    link: `https://instagram.com/${ig.handle}`,
  });
}
if (data.social_profiles?.tiktok) {
  const ttHandle = typeof data.social_profiles.tiktok === 'string' ? data.social_profiles.tiktok : data.social_profiles.tiktok.handle;
  if (ttHandle) {
    socialPlatforms.push({
      platform: 'TikTok',
      icon: 'tt',
      color: '#ffffff',
      handle: `@${ttHandle}`,
      link: `https://tiktok.com/@${ttHandle}`,
    });
  }
}
if (data.social_profiles?.youtube) {
  const ytChannel = typeof data.social_profiles.youtube === 'string' ? data.social_profiles.youtube : data.social_profiles.youtube.channel;
  if (ytChannel) {
    socialPlatforms.push({
      platform: 'YouTube',
      icon: 'yt',
      color: '#FF0000',
      handle: ytChannel,
      link: `https://youtube.com/${ytChannel}`,
    });
  }
}
if (data.social_profiles?.facebook) {
  const fbPage = typeof data.social_profiles.facebook === 'string' ? data.social_profiles.facebook : data.social_profiles.facebook.page;
  if (fbPage) {
    socialPlatforms.push({
      platform: 'Facebook',
      icon: 'fb',
      color: '#1877F2',
      handle: fbPage,
      link: `https://facebook.com/${fbPage}`,
    });
  }
}
if (data.social_profiles?.website) {
  socialPlatforms.push({
    platform: 'Website',
    icon: 'web',
    color: '#cafd00',
    handle: data.social_profiles.website.replace(/^https?:\/\//, '').replace(/\/$/, ''),
    link: data.social_profiles.website,
  });
}
---

<Layout title={`${displayName} -- Competitor Research | CMNDSHFT`}>
  <!-- Header -->
  <header class="border-b border-border bg-surface/50 backdrop-blur-sm sticky top-0 z-50">
    <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
          <div class="w-2 h-2 bg-accent rounded-full pulse-dot"></div>
          <span class="font-display font-bold text-lg tracking-tight">CMNDSHFT</span>
        </a>
        <div class="h-5 w-px bg-border"></div>
        <a href="/research" class="font-label text-sm text-text-secondary font-bold tracking-wide hover:text-accent transition-colors">
          Research
        </a>
        <div class="h-5 w-px bg-border"></div>
        <span class="font-label text-sm text-accent font-bold">@{handle}</span>
      </div>
      <a href="/research" class="text-xs text-text-secondary hover:text-accent transition-colors font-label font-bold tracking-wide">
        &larr; ALL RESEARCH
      </a>
    </div>
  </header>

  <main class="max-w-[1440px] mx-auto px-6 py-8 space-y-12" x-data="detailPage()">

    <!-- ============================================ -->
    <!-- 1. PROFILE HEADER (FULL WIDTH)               -->
    <!-- ============================================ -->
    <section class="card p-8 animate-fade-in-up animate-delay-1" style="border-radius: 16px;">
      <div class="flex items-start gap-6 flex-wrap">
        <!-- Profile Pic -->
        <div class="flex-shrink-0">
          {ig.profile_pic ? (
            <img src={ig.profile_pic} alt={displayName} class="w-24 h-24 rounded-full object-cover ring-3 ring-accent/30" />
          ) : (
            <div class="w-24 h-24 rounded-full bg-accent/10 flex items-center justify-center ring-3 ring-accent/30">
              <span class="text-accent font-display font-bold text-4xl">
                {displayName.charAt(0).toUpperCase()}
              </span>
            </div>
          )}
        </div>

        <!-- Profile Info -->
        <div class="flex-1 min-w-[200px]">
          <div class="flex items-center gap-3 mb-1">
            <h1 class="text-3xl font-display font-bold text-text">{displayName}</h1>
            {ig.is_verified && (
              <svg class="w-6 h-6 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
              </svg>
            )}
          </div>
          <p class="text-sm text-text-secondary font-label mb-3">
            @{handle}{ig.category && ig.category !== 'None' ? ` \u2022 ${ig.category}` : ''}
          </p>
          {ig.bio && (
            <p class="text-sm text-text-secondary leading-relaxed max-w-2xl whitespace-pre-line">{ig.bio}</p>
          )}

          <!-- Platform Links -->
          <div class="flex items-center gap-2 mt-4 flex-wrap">
            {ig.handle && (
              <a href={`https://instagram.com/${ig.handle}`} target="_blank" rel="noopener"
                 class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-label font-bold border border-border hover:border-accent/40 transition-all"
                 style="background: rgba(225,48,108,0.08);">
                <svg class="w-3.5 h-3.5 text-[#E4405F]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                Instagram
              </a>
            )}
            {data.social_profiles?.youtube && (
              <a href={socialPlatforms.find(s => s.icon === 'yt')?.link || '#'} target="_blank" rel="noopener"
                 class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-label font-bold border border-border hover:border-accent/40 transition-all"
                 style="background: rgba(255,0,0,0.08);">
                <svg class="w-3.5 h-3.5 text-[#FF0000]" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                YouTube
              </a>
            )}
            {data.social_profiles?.website && (
              <a href={data.social_profiles.website} target="_blank" rel="noopener"
                 class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-label font-bold border border-border hover:border-accent/40 transition-all bg-accent/5">
                <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
                Website
              </a>
            )}

            <!-- Re-research button -->
            <button
              @click="showReResearch = !showReResearch"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-label font-bold border border-accent/30 text-accent hover:bg-accent/10 transition-all ml-auto cursor-pointer"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 005.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/></svg>
              RE-RESEARCH
            </button>
          </div>

          <!-- Re-research CLI -->
          <div x-show="showReResearch" x-transition class="mt-4 bg-surface-bright rounded-[10px] p-4 border border-border">
            <div class="flex items-center justify-between mb-2">
              <span class="section-label">Run to update this research</span>
              <button @click="copyReResearch()" class="text-xs font-label font-bold text-accent hover:underline">
                <span x-text="copiedReResearch ? 'COPIED!' : 'COPY'"></span>
              </button>
            </div>
            <code class="block bg-background rounded px-3 py-2 text-sm text-accent font-mono break-all select-all">{reResearchCmd}</code>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 gap-4 flex-shrink-0">
          <div class="bg-surface-bright/50 rounded-[10px] px-5 py-4 text-center min-w-[90px]">
            <div class="stat-value text-xl">{formatNumber(ig.followers || 0)}</div>
            <div class="section-label mt-1">Followers</div>
          </div>
          <div class="bg-surface-bright/50 rounded-[10px] px-5 py-4 text-center min-w-[90px]">
            <div class="font-display font-bold text-xl text-text">{formatNumber(ig.following || 0)}</div>
            <div class="section-label mt-1">Following</div>
          </div>
          <div class="bg-surface-bright/50 rounded-[10px] px-5 py-4 text-center min-w-[90px]">
            <div class="font-display font-bold text-xl text-text">{formatNumber(ig.posts_count || 0)}</div>
            <div class="section-label mt-1">Total Posts</div>
          </div>
          <div class="bg-surface-bright/50 rounded-[10px] px-5 py-4 text-center min-w-[90px]">
            <div class="font-display font-bold text-xl text-text">{ads.length}</div>
            <div class="section-label mt-1">Ads Found</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 2. SOCIAL PRESENCE (CARD ROW)                -->
    <!-- ============================================ -->
    {socialPlatforms.length > 1 && (
      <section class="animate-fade-in-up animate-delay-2">
        <div class="flex items-center gap-3 mb-5">
          <h2 class="text-xl font-display font-bold">Social Presence</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
          {socialPlatforms.map((sp, i) => (
            <a href={sp.link} target="_blank" rel="noopener"
               class={`card p-5 flex flex-col gap-3 hover:border-accent/40 transition-all`} style="border-radius: 12px;">
              <div class="flex items-center gap-2">
                {sp.icon === 'ig' && (
                  <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background: linear-gradient(45deg, #405de6, #c13584, #fd1d1d, #f56040);">
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  </div>
                )}
                {sp.icon === 'tt' && (
                  <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-black" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .55.04.81.11v-3.5a6.37 6.37 0 00-.81-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V9.15a8.16 8.16 0 004.76 1.52v-3.4a4.85 4.85 0 01-1-.58z"/></svg>
                  </div>
                )}
                {sp.icon === 'yt' && (
                  <div class="w-8 h-8 rounded-full bg-[#FF0000] flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  </div>
                )}
                {sp.icon === 'fb' && (
                  <div class="w-8 h-8 rounded-full bg-[#1877F2] flex items-center justify-center flex-shrink-0">
                    <span class="text-white text-xs font-bold">f</span>
                  </div>
                )}
                {sp.icon === 'web' && (
                  <div class="w-8 h-8 rounded-full bg-accent/15 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
                  </div>
                )}
                <span class="font-label font-bold text-sm">{sp.platform}</span>
              </div>
              {sp.followers && (
                <div class="stat-value text-lg">{formatNumber(sp.followers)}</div>
              )}
              <span class="text-xs text-text-secondary truncate">{sp.handle}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ============================================ -->
    <!-- 3. TOP VIRAL POSTS                           -->
    <!-- ============================================ -->
    {posts.length > 0 && (
      <section class="animate-fade-in-up animate-delay-3">
        <div class="flex items-center gap-3 mb-5">
          <h2 class="text-xl font-display font-bold">Top Viral Posts</h2>
          <span class="section-label mt-0.5">{posts.length} posts by engagement</span>
        </div>

        <!-- Post Cards Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
          {posts.slice(0, 20).map((post: any, i: number) => (
            <div class={`card p-0 overflow-hidden flex animate-fade-in-up animate-delay-${Math.min(i + 1, 6)}`} style="border-radius: 12px;">
              <!-- Thumbnail -->
              {post.thumbnail ? (
                <a href={post.url} target="_blank" rel="noopener" class="flex-shrink-0 w-28 min-h-[120px] overflow-hidden relative group">
                  <img src={post.thumbnail} alt="" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
                  <div class="absolute inset-0 bg-black/30 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
                  </div>
                </a>
              ) : (
                <div class="flex-shrink-0 w-28 min-h-[120px] bg-surface-bright flex items-center justify-center">
                  <span class="text-text-secondary text-2xl font-display font-bold">{i + 1}</span>
                </div>
              )}

              <!-- Post Content -->
              <div class="flex-1 p-4 flex flex-col gap-2 min-w-0">
                <!-- Hook Text -->
                <a href={post.url} target="_blank" rel="noopener" class="text-sm text-text hover:text-accent transition-colors leading-snug line-clamp-2 font-medium">
                  {post.hook_text || post.caption?.slice(0, 120) || 'No caption'}
                </a>

                <!-- Badges Row -->
                <div class="flex items-center gap-2 flex-wrap">
                  <span class={`badge ${getFrameworkColor(post.hook_framework).badge}`}>{post.hook_framework}</span>
                  <span class={`badge ${post.type === 'reel' || post.type === 'video' ? 'badge-lime' : post.type === 'carousel' ? 'badge-warm' : 'badge-grey'}`}>
                    {post.type === 'video' ? 'REEL' : (post.type || 'POST').toUpperCase()}
                  </span>
                  {post.date && (
                    <span class="text-xs text-text-secondary font-label">{formatDate(post.date)}</span>
                  )}
                </div>

                <!-- Stats Row -->
                <div class="flex items-center gap-4 mt-auto pt-1">
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-text-secondary" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    <span class="text-sm font-label font-bold text-text">{formatNumber(post.likes)}</span>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-text-secondary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                    <span class="text-sm font-label text-text-secondary">{formatNumber(post.comments)}</span>
                  </div>
                  <div class="flex items-center gap-1.5 ml-auto">
                    <svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    <span class="text-sm font-label font-bold text-accent">{formatNumber(post.engagement)}</span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ============================================ -->
    <!-- 4. AD LIBRARY (FOREPLAY-STYLE)               -->
    <!-- ============================================ -->
    {ads.length > 0 && (ads.some((a: any) => a.headline || a.body)) && (
      <section class="animate-fade-in-up animate-delay-4">
        <div class="flex items-center justify-between mb-5 flex-wrap gap-4">
          <div class="flex items-center gap-3">
            <h2 class="text-xl font-display font-bold">Ad Library</h2>
            <span class="section-label mt-0.5">{activeAds.length} active, {inactiveAds.length} inactive</span>
          </div>

          <!-- Sort / Filter Controls -->
          <div class="flex items-center gap-2" x-data="{ adSort: 'longest', adFilter: 'all' }">
            <select x-model="adSort" @change="sortAds()" class="bg-surface-bright border border-border rounded-[8px] px-3 py-1.5 text-xs font-label font-bold text-text-secondary cursor-pointer focus:outline-none focus:border-accent/50">
              <option value="longest">Longest Running</option>
              <option value="recent">Most Recent</option>
              <option value="active">Active Only</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5" id="ads-grid">
          {ads.filter((a: any) => a.headline || a.body).map((ad: any, i: number) => (
            <div
              class={`card p-0 overflow-hidden flex flex-col transition-all animate-fade-in-up animate-delay-${Math.min(i + 1, 6)}`}
              style={`border-radius: 12px; border-left: 3px solid ${ad.is_active ? '#22c55e' : '#ef4444'};`}
              data-days-live={ad.days_live}
              data-start-date={ad.start_date}
              data-is-active={ad.is_active}
            >
              <!-- Ad Header -->
              <div class="p-5 pb-3">
                <div class="flex items-center gap-2 mb-3">
                  <span class={`w-2.5 h-2.5 rounded-full flex-shrink-0 ${ad.is_active ? 'bg-[#22c55e]' : 'bg-[#ef4444]'}`}
                        style={ad.is_active ? 'box-shadow: 0 0 8px rgba(34,197,94,0.4)' : ''}></span>
                  <span class={`font-label font-bold text-xs tracking-wider ${ad.is_active ? 'text-[#22c55e]' : 'text-[#ef4444]'}`}>
                    {ad.is_active ? 'ACTIVE' : 'INACTIVE'}
                  </span>
                  <span class="text-text-secondary/60 text-xs mx-1">&bull;</span>
                  <span class={`text-xs font-label font-bold ${ad.is_active ? 'text-[#22c55e]' : 'text-[#ef4444]'}`}>
                    {ad.days_live > 0
                      ? (ad.is_active ? `Running ${ad.days_live} days` : `Stopped after ${ad.days_live} days`)
                      : 'New'}
                  </span>
                </div>

                <!-- Days Live Progress Bar -->
                {ad.days_live > 0 && (
                  <div class="mb-3">
                    <div class="h-1.5 bg-surface-bright rounded-full overflow-hidden">
                      <div
                        class={`h-full rounded-full transition-all duration-500 ${ad.is_active ? 'bg-[#22c55e]' : 'bg-[#ef4444]/50'}`}
                        style={`width: ${Math.min((ad.days_live / 90) * 100, 100)}%`}
                      ></div>
                    </div>
                  </div>
                )}

                <!-- Headline -->
                {ad.headline && (
                  <h3 class="font-display font-bold text-sm text-text leading-tight mb-2">{ad.headline}</h3>
                )}
              </div>

              <!-- Ad Body -->
              {ad.body && (
                <div class="px-5 pb-3">
                  <p class="text-xs text-text-secondary leading-relaxed line-clamp-3">{ad.body}</p>
                </div>
              )}

              <!-- Thumbnail -->
              {ad.thumbnail && (
                <div class="px-5 pb-3">
                  <img src={ad.thumbnail} alt="" class="w-full h-40 object-cover rounded-[8px]" loading="lazy" />
                </div>
              )}

              <!-- Ad Meta Footer -->
              <div class="mt-auto border-t border-border/50 px-5 py-3 flex items-center gap-2 flex-wrap bg-surface-bright/20">
                {ad.cta && (
                  <span class="badge badge-lime">{ad.cta}</span>
                )}
                {ad.platforms?.map((platform: string) => {
                  const plat = platform.toLowerCase();
                  const label = plat === 'facebook' ? 'FB' : plat === 'instagram' ? 'IG' : plat === 'audience_network' ? 'AN' : plat === 'messenger' ? 'MSG' : platform;
                  return (
                    <span class="badge badge-grey">{label}</span>
                  );
                })}
                {ad.start_date && (
                  <span class="text-xs text-text-secondary font-label ml-auto">
                    {formatDate(ad.start_date)}{ad.end_date ? ` - ${formatDate(ad.end_date)}` : ' - Present'}
                  </span>
                )}
                {(ad.spend_lower || ad.spend_upper) && (
                  <span class="text-xs text-text-secondary font-label">
                    Est. ${ad.spend_lower || '?'}-${ad.spend_upper || '?'}
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ============================================ -->
    <!-- 5. CONTENT COMPETITORS                       -->
    <!-- ============================================ -->
    {competitors.length > 0 && (
      <section class="animate-fade-in-up animate-delay-5">
        <div class="flex items-center gap-3 mb-5">
          <h2 class="text-xl font-display font-bold">Content Competitors</h2>
          <span class="section-label mt-0.5">{competitors.length} niche competitors</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {competitors.map((comp: any, i: number) => {
            const compCmd = `cd ~/content-engine && uv run python3 scripts/competitor-research.py '@${comp.handle}'`;
            const overlapPct = comp.content_overlap ? `${Math.round(comp.content_overlap * 100)}%` : null;
            return (
              <div class={`card p-5 flex flex-col gap-3 animate-fade-in-up animate-delay-${Math.min(i + 1, 6)}`} style="border-radius: 12px;">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                    <span class="text-accent font-display font-bold text-sm">
                      {comp.handle.charAt(0).toUpperCase()}
                    </span>
                  </div>
                  <div class="min-w-0 flex-1">
                    <a href={`https://instagram.com/${comp.handle}`} target="_blank" rel="noopener"
                       class="font-label font-bold text-sm text-text hover:text-accent transition-colors truncate block">
                      @{comp.handle}
                    </a>
                    {comp.niche && (
                      <p class="text-xs text-text-secondary truncate mt-0.5">{comp.niche}</p>
                    )}
                  </div>
                </div>

                <!-- Stats Row -->
                <div class="flex items-center gap-3 flex-wrap">
                  {comp.followers > 0 && (
                    <div class="flex items-center gap-1.5">
                      <span class="section-label">Followers</span>
                      <span class="font-display font-bold text-accent text-sm">{formatNumber(comp.followers)}</span>
                    </div>
                  )}
                  {overlapPct && (
                    <div class="flex items-center gap-1.5">
                      <span class="section-label">Overlap</span>
                      <span class="font-display font-bold text-sm text-text">{overlapPct}</span>
                    </div>
                  )}
                </div>

                <!-- Badges -->
                <div class="flex items-center gap-2 flex-wrap">
                  <span class={`badge ${comp.similarity === 'high' ? 'badge-lime' : comp.similarity === 'medium' ? 'badge-warm' : 'badge-grey'}`}>
                    {comp.similarity} match
                  </span>
                  {comp.source && comp.source !== 'instagram_related' && (
                    <span class="badge badge-grey">
                      {comp.source === 'content_niche_match' ? 'niche match' : comp.source === 'hashtag_discovery' ? 'hashtag discovery' : comp.source === 'monitored_list' ? 'monitored' : comp.source}
                    </span>
                  )}
                </div>

                <!-- Why competitor -->
                {comp.why_competitor && (
                  <p class="text-xs text-text-secondary leading-relaxed">{comp.why_competitor}</p>
                )}

                <!-- Shared niche tags -->
                {comp.niche_tags_shared && comp.niche_tags_shared.length > 0 && (
                  <div class="flex flex-wrap gap-1">
                    {comp.niche_tags_shared.slice(0, 5).map((tag: string) => (
                      <span class="text-[10px] px-1.5 py-0.5 rounded bg-accent/8 text-accent/70 font-label font-bold">#{tag}</span>
                    ))}
                  </div>
                )}

                <button
                  @click={`showCompResearch = showCompResearch === '${comp.handle}' ? null : '${comp.handle}'`}
                  class="mt-auto text-xs text-accent font-label font-bold hover:underline text-left cursor-pointer"
                >
                  RESEARCH THIS &rarr;
                </button>
                <div x-show={`showCompResearch === '${comp.handle}'`} x-transition class="bg-surface-bright rounded-[8px] p-3 border border-border">
                  <code class="text-xs text-accent font-mono break-all select-all block">{compCmd}</code>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- ============================================ -->
    <!-- 6. STRATEGY ANALYSIS                         -->
    <!-- ============================================ -->
    {(analysis.top_hooks?.length > 0 || analysis.content_themes?.length > 0 || analysis.posting_frequency || analysis.best_performing_format || analysis.ad_strategy_notes) && (
      <section class="animate-fade-in-up animate-delay-6">
        <div class="flex items-center gap-3 mb-5">
          <h2 class="text-xl font-display font-bold">Strategy Analysis</h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Top Hook Patterns -->
          {analysis.top_hooks?.length > 0 && (
            <div class="card p-6" style="border-radius: 12px;">
              <h3 class="font-display font-bold text-sm mb-4 flex items-center gap-2">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                Top Hook Patterns
              </h3>
              <div class="space-y-3">
                {analysis.top_hooks.map((hook: string, i: number) => (
                  <div class="flex gap-3 items-start">
                    <span class="text-accent font-display font-bold text-sm flex-shrink-0 mt-0.5 w-5">{i + 1}.</span>
                    <p class="text-sm text-text-secondary leading-relaxed">&ldquo;{hook}&rdquo;</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Content Themes + Performance -->
          <div class="space-y-6">
            {analysis.content_themes?.length > 0 && (
              <div class="card p-6" style="border-radius: 12px;">
                <h3 class="font-display font-bold text-sm mb-4 flex items-center gap-2">
                  <svg class="w-4 h-4 text-warm" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>
                  Content Themes
                </h3>
                <div class="flex flex-wrap gap-2">
                  {analysis.content_themes.map((theme: string) => (
                    <span class="badge badge-lime">{theme}</span>
                  ))}
                </div>
              </div>
            )}

            <div class="card p-6" style="border-radius: 12px;">
              <h3 class="font-display font-bold text-sm mb-4 flex items-center gap-2">
                <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>
                Performance Summary
              </h3>
              <div class="space-y-4">
                {analysis.posting_frequency && (
                  <div>
                    <span class="section-label">Posting Frequency</span>
                    <p class="text-sm text-text mt-1 font-medium">{analysis.posting_frequency}</p>
                  </div>
                )}
                {analysis.best_performing_format && (
                  <div>
                    <span class="section-label">Best Performing Format</span>
                    <p class="text-sm text-text mt-1 font-medium">{analysis.best_performing_format}</p>
                  </div>
                )}
                {analysis.ad_strategy_notes && (
                  <div>
                    <span class="section-label">Ad Strategy</span>
                    <p class="text-sm text-text-secondary mt-1 leading-relaxed">{analysis.ad_strategy_notes}</p>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="border-t border-border pt-6 pb-8 text-center">
      <p class="section-label">CMNDSHFT Competitor Intelligence</p>
      <p class="text-xs text-text-secondary mt-1">
        Research generated {formatDate(data.timestamp)} via content-engine pipeline
      </p>
    </footer>

  </main>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js" defer></script>

<script is:inline>
  function detailPage() {
    return {
      showReResearch: false,
      copiedReResearch: false,
      showCompResearch: null,

      copyReResearch() {
        const code = document.querySelector('.bg-background.rounded code, code.text-accent.font-mono');
        if (code) {
          navigator.clipboard.writeText(code.textContent || '');
          this.copiedReResearch = true;
          setTimeout(() => this.copiedReResearch = false, 2000);
        }
      },
    };
  }
</script>
