---
import Layout from '../../layouts/Layout.astro';

// Load all research JSON files from the data directory
const researchFiles = import.meta.glob('../../data/research/*.json', { eager: true });

interface ResearchEntry {
  query: string;
  slug: string;
  timestamp: string;
  social_profiles: {
    instagram?: {
      handle?: string;
      full_name?: string;
      followers?: number;
      following?: number;
      posts_count?: number;
      bio?: string;
      profile_pic?: string;
      is_verified?: boolean;
      category?: string;
    };
    tiktok?: any;
    youtube?: any;
    facebook?: any;
    website?: string;
  };
  viral_posts: any[];
  ads: any[];
  competitors: any[];
  analysis?: any;
}

const entries: ResearchEntry[] = Object.values(researchFiles)
  .map((mod: any) => mod.default || mod)
  .filter((d: any) => d.slug && !d.slug.startsWith('_'))
  .sort((a: any, b: any) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());

function formatNumber(n: number): string {
  if (!n) return '0';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
  return n.toLocaleString();
}

function formatDate(ts: string): string {
  return new Date(ts).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Compute total stats
const totalCompetitors = entries.length;
const totalPosts = entries.reduce((sum, e) => sum + (e.viral_posts?.length || 0), 0);
const totalAds = entries.reduce((sum, e) => sum + (e.ads?.length || 0), 0);
const activeAdsTotal = entries.reduce((sum, e) => sum + (e.ads?.filter((a: any) => a.is_active)?.length || 0), 0);
---

<Layout title="Competitor Research | CMNDSHFT">
  <!-- Header -->
  <header class="border-b border-border bg-surface/50 backdrop-blur-sm sticky top-0 z-50">
    <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
          <div class="w-2 h-2 bg-accent rounded-full pulse-dot"></div>
          <span class="font-display font-bold text-lg tracking-tight">CMNDSHFT</span>
        </a>
        <div class="h-5 w-px bg-border"></div>
        <span class="font-label text-sm text-accent font-bold tracking-wide">Competitor Research</span>
      </div>
      <a href="/" class="text-xs text-text-secondary hover:text-accent transition-colors font-label font-bold tracking-wide">
        &larr; BACK TO DASHBOARD
      </a>
    </div>
  </header>

  <main class="max-w-[1440px] mx-auto px-6 py-8 space-y-10" x-data="researchApp()">

    <!-- ============================================ -->
    <!-- HERO / TITLE SECTION                         -->
    <!-- ============================================ -->
    <section class="text-center pt-4 pb-2 animate-fade-in-up animate-delay-1">
      <h1 class="text-4xl font-display font-bold mb-3 tracking-tight">Competitor Research</h1>
      <p class="text-text-secondary text-base max-w-2xl mx-auto leading-relaxed mb-6">
        Enter any Instagram handle or website to analyze their content strategy, viral posts, and ad library
      </p>
      <div class="flex items-center justify-center gap-6">
        <div class="text-center">
          <div class="stat-value text-2xl">{totalCompetitors}</div>
          <div class="section-label mt-1">Competitors Researched</div>
        </div>
        <div class="w-px h-10 bg-border"></div>
        <div class="text-center">
          <div class="font-display font-bold text-2xl text-text">{totalPosts}</div>
          <div class="section-label mt-1">Posts Analyzed</div>
        </div>
        <div class="w-px h-10 bg-border"></div>
        <div class="text-center">
          <div class="font-display font-bold text-2xl text-text">{totalAds}</div>
          <div class="section-label mt-1">Ads Found</div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SEARCH BAR                                   -->
    <!-- ============================================ -->
    <section class="animate-fade-in-up animate-delay-2">
      <div class="max-w-3xl mx-auto">
        <div class="card p-2 flex items-center gap-2" style="border-radius: 16px;">
          <!-- Platform badge (auto-detect) -->
          <div class="flex-shrink-0 pl-3">
            <template x-if="detectedPlatform === 'ig'">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-label font-bold"
                    style="background: linear-gradient(45deg, #405de6, #c13584, #fd1d1d, #f56040); color: white;">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                IG
              </span>
            </template>
            <template x-if="detectedPlatform === 'tt'">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-label font-bold bg-white text-black">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .55.04.81.11v-3.5a6.37 6.37 0 00-.81-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V9.15a8.16 8.16 0 004.76 1.52v-3.4a4.85 4.85 0 01-1-.58z"/></svg>
                TT
              </span>
            </template>
            <template x-if="detectedPlatform === 'yt'">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-label font-bold bg-[#FF0000] text-white">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                YT
              </span>
            </template>
            <template x-if="detectedPlatform === 'web'">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-label font-bold bg-accent/20 text-accent border border-accent/30">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
                WEB
              </span>
            </template>
            <template x-if="!detectedPlatform">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-label font-bold bg-surface-bright text-text-secondary">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                ?
              </span>
            </template>
          </div>

          <input
            x-model="searchInput"
            @input="detectPlatform()"
            @keydown.enter="showCommand()"
            type="text"
            placeholder="Enter @handle or website URL..."
            class="flex-1 bg-transparent border-none px-3 py-3.5 text-base text-text placeholder:text-text-secondary/40 font-sans focus:outline-none"
            style="border-radius: 0;"
          />

          <button
            @click="showCommand()"
            class="flex-shrink-0 bg-accent text-on-accent px-7 py-3.5 font-label font-bold text-sm tracking-wider hover:brightness-110 transition-all flex items-center gap-2"
            style="border-radius: 12px;"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            RESEARCH
          </button>
        </div>

        <!-- CLI Command Modal -->
        <div x-show="showCli" x-transition.opacity class="mt-4 card p-5" style="border-radius: 12px;">
          <div class="flex items-center justify-between mb-3">
            <span class="section-label">Run this command in your terminal</span>
            <button @click="copyCommand()" class="text-xs font-label font-bold text-accent hover:underline flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span x-text="copied ? 'COPIED!' : 'COPY'"></span>
            </button>
          </div>
          <code x-ref="cliCode" class="block bg-surface-bright rounded-[8px] px-4 py-3 text-sm text-accent font-mono break-all select-all" x-text="cliCommand"></code>
          <p class="text-xs text-text-secondary mt-3">After it completes, run <code class="text-accent">npm run build</code> and refresh this page to see results.</p>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- RESEARCH RESULTS GRID                        -->
    <!-- ============================================ -->
    <section class="animate-fade-in-up animate-delay-3">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-xl font-display font-bold">Previous Research</h2>
        <span class="section-label mt-0.5">{entries.length} reports</span>
      </div>

      {entries.length === 0 ? (
        <div class="card p-16 text-center" style="border-radius: 12px;">
          <div class="w-16 h-16 rounded-full bg-surface-bright flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-text-secondary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </div>
          <p class="text-text-secondary text-sm mb-2">No research reports yet.</p>
          <p class="text-text-secondary/60 text-xs">Use the search bar above to research your first competitor.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {entries.map((entry, i) => {
            const ig = entry.social_profiles?.instagram || {};
            const displayName = ig.full_name || ig.handle || entry.query;
            const handle = ig.handle || entry.slug;
            const slug = entry.slug?.replace(/^_sample-/, '') || entry.slug;
            const topHook = entry.viral_posts?.[0]?.hook_text || '';
            const hasActiveAds = entry.ads?.some((a: any) => a.is_active && (a.headline || a.body));
            return (
              <div class={`card p-0 overflow-hidden flex flex-col animate-fade-in-up animate-delay-${Math.min(i + 1, 6)}`} style="border-radius: 12px;">
                <!-- Card Header -->
                <div class="p-6 pb-4">
                  <div class="flex items-start gap-4">
                    {ig.profile_pic ? (
                      <img src={ig.profile_pic} alt={displayName} class="w-14 h-14 rounded-full object-cover flex-shrink-0 ring-2 ring-accent/20" />
                    ) : (
                      <div class="w-14 h-14 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 ring-2 ring-accent/20">
                        <span class="text-accent font-display font-bold text-xl">
                          {displayName.charAt(0).toUpperCase()}
                        </span>
                      </div>
                    )}
                    <div class="flex-1 min-w-0">
                      <h3 class="font-display font-bold text-base text-text truncate leading-tight">{displayName}</h3>
                      <p class="text-xs text-text-secondary font-label mt-0.5">@{handle}</p>
                    </div>
                  </div>
                </div>

                <!-- Stats Row -->
                <div class="px-6 pb-4">
                  <div class="grid grid-cols-3 gap-3">
                    <div class="bg-surface-bright/50 rounded-[8px] px-3 py-2.5 text-center">
                      <div class="font-display font-bold text-accent text-sm">{formatNumber(ig.followers || 0)}</div>
                      <div class="section-label mt-0.5" style="font-size: 0.6rem;">Followers</div>
                    </div>
                    <div class="bg-surface-bright/50 rounded-[8px] px-3 py-2.5 text-center">
                      <div class="font-display font-bold text-text text-sm">{entry.viral_posts?.length || 0}</div>
                      <div class="section-label mt-0.5" style="font-size: 0.6rem;">Posts</div>
                    </div>
                    <div class="bg-surface-bright/50 rounded-[8px] px-3 py-2.5 text-center relative">
                      <div class="font-display font-bold text-text text-sm">{entry.ads?.length || 0}</div>
                      <div class="section-label mt-0.5" style="font-size: 0.6rem;">Ads</div>
                      {hasActiveAds && (
                        <span class="absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-[#22c55e]" style="box-shadow: 0 0 6px rgba(34,197,94,0.5);"></span>
                      )}
                    </div>
                  </div>
                </div>

                <!-- Top Hook Preview -->
                {topHook && (
                  <div class="px-6 pb-4">
                    <div class="text-xs text-text-secondary/70 leading-relaxed line-clamp-2 italic">
                      &ldquo;{topHook}&rdquo;
                    </div>
                  </div>
                )}

                <!-- Card Footer -->
                <div class="mt-auto border-t border-border/50 px-6 py-3.5 flex items-center justify-between bg-surface-bright/20">
                  <span class="text-xs text-text-secondary font-label">{formatDate(entry.timestamp)}</span>
                  <a href={`/research/${slug}`} class="text-xs text-accent font-label font-bold tracking-wide hover:underline">
                    VIEW FULL REPORT &rarr;
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>

    <!-- Footer -->
    <footer class="border-t border-border pt-6 pb-8 text-center">
      <p class="section-label">CMNDSHFT Competitor Intelligence</p>
      <p class="text-xs text-text-secondary mt-1">
        Powered by content-engine research pipeline
      </p>
    </footer>
  </main>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js" defer></script>

<script is:inline>
  function researchApp() {
    return {
      searchInput: '',
      detectedPlatform: null,
      showCli: false,
      cliCommand: '',
      copied: false,

      detectPlatform() {
        const val = this.searchInput.trim().toLowerCase();
        if (!val) {
          this.detectedPlatform = null;
          return;
        }
        if (val.startsWith('@') || val.includes('instagram.com')) {
          this.detectedPlatform = 'ig';
        } else if (val.includes('tiktok.com')) {
          this.detectedPlatform = 'tt';
        } else if (val.includes('youtube.com') || val.includes('youtu.be')) {
          this.detectedPlatform = 'yt';
        } else if (val.includes('http') || val.includes('.com') || val.includes('.io') || val.includes('.co')) {
          this.detectedPlatform = 'web';
        } else {
          // Assume IG handle if no URL markers
          this.detectedPlatform = 'ig';
        }
      },

      showCommand() {
        const val = this.searchInput.trim();
        if (!val) return;
        const escaped = val.replace(/'/g, "\\'");
        this.cliCommand = `cd ~/content-engine && uv run python3 scripts/competitor-research.py '${escaped}'`;
        this.showCli = true;
      },

      copyCommand() {
        navigator.clipboard.writeText(this.cliCommand);
        this.copied = true;
        setTimeout(() => this.copied = false, 2000);
      }
    };
  }
</script>
