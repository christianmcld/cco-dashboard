---
interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FieldWork Content Engine · Build Online. Live Offline. · content intelligence dashboard" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- No-flash theme: apply saved theme before paint (default light) -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('cco-theme');
          if (t === 'dark') document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.9/dist/cdn.min.js" defer></script>
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-text">
    <!-- Dotted surface background -->
    <div class="dotted-surface" aria-hidden="true"></div>

    <!-- App layout wrapper -->
    <div
      x-data="{
        sidebarOpen: true,
        mobileSidebar: false,
        dark: document.documentElement.classList.contains('dark'),
        toggleTheme() {
          this.dark = !this.dark;
          document.documentElement.classList.toggle('dark', this.dark);
          try { localStorage.setItem('cco-theme', this.dark ? 'dark' : 'light'); } catch (e) {}
        }
      }"
      x-init="sidebarOpen = window.innerWidth > 1024"
    >

      <!-- SIDEBAR NAVIGATION -->
      <aside
        class="sidebar"
        :class="{ 'collapsed': !sidebarOpen, 'mobile-open': mobileSidebar }"
      >
        <div class="px-4 py-3 flex items-center gap-3 border-b border-border min-h-[64px]">
          <div class="w-2 h-2 bg-accent rounded-full pulse-dot flex-shrink-0"></div>
          <div class="overflow-hidden" x-show="sidebarOpen" x-transition>
            <img src="/brand/signature-black.png" alt="Christian McLeod" class="h-6 w-auto block dark:hidden" />
            <img src="/brand/signature-white.png" alt="Christian McLeod" class="h-6 w-auto hidden dark:block" />
            <span class="block mt-0.5 font-label text-[0.6rem] font-semibold uppercase tracking-[0.16em] text-text-secondary whitespace-nowrap">Build Online · Live Offline</span>
          </div>
        </div>

        <nav class="flex-1 py-3 space-y-1">
          <a href="/" class={`sidebar-link ${currentPath === '/' ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="0"></rect><rect x="14" y="3" width="7" height="7" rx="0"></rect><rect x="3" y="14" width="7" height="7" rx="0"></rect><rect x="14" y="14" width="7" height="7" rx="0"></rect></svg>
            <span x-show="sidebarOpen" x-transition>Dashboard</span>
          </a>
          <a href="/outliers" class={`sidebar-link ${currentPath.startsWith('/outliers') ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
            <span x-show="sidebarOpen" x-transition>Content Outliers</span>
          </a>
          <a href="/research" class={`sidebar-link ${currentPath.startsWith('/research') ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <span x-show="sidebarOpen" x-transition>Competitor Research</span>
          </a>
          <a href="/library" class={`sidebar-link ${currentPath.startsWith('/library') ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
            <span x-show="sidebarOpen" x-transition>Library</span>
          </a>
          <a href="/belief" class={`sidebar-link ${currentPath.startsWith('/belief') ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"></path></svg>
            <span x-show="sidebarOpen" x-transition>Belief Score</span>
          </a>
          <a href="#" class="sidebar-link" onclick="return false">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"></path></svg>
            <span x-show="sidebarOpen" x-transition>Settings</span>
          </a>
        </nav>

        <div class="p-3 border-t border-border space-y-1">
          <!-- Theme toggle -->
          <button
            @click="toggleTheme()"
            class="sidebar-link w-full justify-center"
            :aria-label="dark ? 'Switch to light mode' : 'Switch to dark mode'"
          >
            <!-- Sun (shown in dark mode, click -> light) -->
            <svg x-show="dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>
            <!-- Moon (shown in light mode, click -> dark) -->
            <svg x-show="!dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            <span x-show="sidebarOpen" x-transition class="text-xs" x-text="dark ? 'Light mode' : 'Dark mode'"></span>
          </button>
          <!-- Collapse -->
          <button
            @click="sidebarOpen = !sidebarOpen"
            class="sidebar-link w-full justify-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" :class="{ 'rotate-180': !sidebarOpen }" class="transition-transform"><polyline points="15 18 9 12 15 6"></polyline></svg>
            <span x-show="sidebarOpen" x-transition class="text-xs">Collapse</span>
          </button>
        </div>
      </aside>

      <!-- MOBILE MENU BUTTON -->
      <button
        class="fixed top-4 right-4 z-[110] p-2 card lg:hidden"
        @click="mobileSidebar = !mobileSidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>

      <!-- MAIN CONTENT -->
      <main
        class="main-with-sidebar min-h-screen"
        :class="{ 'sidebar-collapsed': !sidebarOpen }"
      >
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
